[
	{
		"name": "theme_info",
		"theme_name": "CartCraft Portfolio",
		"theme_version": "0.1.0",
		"theme_author": "Nadiia Azarova",
		"theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
		"theme_support_url": "https://support.shopify.com/"
	},
	{
		"name": "t:general.typography",
		"settings": [
			{
				"type": "header",
				"content": "t:general.fonts"
			},
			{
				"type": "font_picker",
				"id": "font_heading",
				"default": "lora_n4",
				"label": "Heading font"
			},
			{
				"type": "font_picker",
				"id": "font_body",
				"default": "poppins_n4",
				"label": "Body font"
			}
		]
	},
	{
		"name": "t:general.layout",
		"settings": [
			{
				"type": "select",
				"id": "max_page_width",
				"label": "t:labels.page_width",
				"options": [
					{
						"value": "90rem",
						"label": "t:options.page_width.narrow"
					},
					{
						"value": "110rem",
						"label": "t:options.page_width.wide"
					}
				],
				"default": "90rem"
			},
			{
				"type": "range",
				"id": "min_page_margin",
				"min": 10,
				"max": 100,
				"step": 1,
				"unit": "px",
				"label": "t:labels.page_margin",
				"default": 20
			}
		]
	},
	{
		"name": "t:general.colors",
		"settings": [
			{
				"type": "color",
				"id": "background_color",
				"default": "#FFFFFF",
				"label": "t:labels.background"
			},
			{
				"type": "color",
				"id": "foreground_color",
				"default": "#333333",
				"label": "t:labels.foreground"
			},
			{
				"type": "range",
				"id": "input_corner_radius",
				"min": 0,
				"max": 10,
				"step": 1,
				"unit": "px",
				"label": "t:labels.input_corner_radius",
				"default": 4
			}
		]
	}
]
