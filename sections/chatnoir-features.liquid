<div class="container">
	<div class="features__content">
		<h2 class="features__h2 heading heading_b">{{ section.settings.heading }}</h2>
		<ul class="features__list">
			{% for block in section.blocks %} 
				<li class="features__item">
					<h3 class="features__heading heading heading_c">{{ block.settings.feature_heading }}</h3>
					<p class="features__txt">{{ block.settings.feature_text }}</p>
				</li>
			{% endfor %}
			
			
		</ul>
		<ul class="features__controls controls-list">
			{% for block in section.blocks %}
				<li class="controls-list__item">
					<div class="controls-list__control"></div>
				</li>
			{% endfor %}
		</ul>
	</div>
</div>

{% schema %}
	{
		"name": "Product Features Carousel",
		"tag": "section",
		"class": "main__section features",
		"limit": 1,
		"settings": [
			{
				"type": "text",
				"id": "heading",
				"label": "Heading",
				"default": "Designed for Those Who Appreciate Craft"
			}
		],
		"blocks": [
			{
				"type": "feature",
				"name": "Product Feature",
				"limit": 6,
				"settings": [
					{
						"type": "header",
						"content": "Product Feature Settings"
					},
					{
						"type": "text",
						"id": "feature_heading",
						"label": "Feature Heading"
					},
					{
						"type": "textarea",
						"id": "feature_text",
						"label": "Feature Text"
					}
				]
			}
		],
		"presets": [
			{
				"name": "Product Feature Carousel",
				"blocks": [
					{
						"type": "feature",
						"settings": {
							"feature_heading": "Premium Full-Grain Leather",
							"feature_text": "Carefully selected for its rich texture, natural character, and exceptional durability that only improves with age."
						}
					},
					{
						"type": "feature",
						"settings": {
							"feature_heading": "Handcrafted Construction",
							"feature_text": "Each backpack is individually assembled and finished by hand using traditional leatherworking techniques."
						}
					},
					{
						"type": "feature",
						"settings": {
							"feature_heading": "Made for You",
							"feature_text": "Crafted to order and personalized to your preferences, creating a piece that is uniquely yours."
						}
					}
				]
			}
		]
	}
{% endschema %}
