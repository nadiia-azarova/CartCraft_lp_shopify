<div class="container">
	<div class="faq__content">
		<h2 class="faq__h2 heading heading_b">{{ section.settings.heading }}</h2>
		<ul class="faq__ul faq-list">
			{% for block in section.blocks %}  
				<li class="faq-list__item faq-list__item_opened" {{ block.shopify_attributes }}>
					<div class="faq-list__question">
						<h3 class="faq-list__h3 heading heading_c">{{ block.settings.question }}</h3>
						<div class="faq-list__icon">
							{% render 'icon', icon: 'plus' %}
						</div>
					</div>
					<div class="faq-list__answer">
						<p class="faq-list__p">{{ block.settings.answer }}</p>
					</div>
				</li>
			{% endfor %}
		</ul>
	</div>
</div>

{% schema  %}
	{
		"name": "FAQ Section",
		"tag": "section",
		"class": "main__section faq",
		"limit": 1,
		"settings": [
			{
				"type": "text",
				"id": "heading",
				"label": "Section Heading",
				"default": "Got Questions?"
			}
		],
		"blocks": [
			{
				"type": "accordion-item",
				"name": "Accordion Element",
				"settings": [
					{
						"type": "text",
						"id": "question",
						"label": "Question Text"
					},
					{
						"type": "textarea",
						"id": "answer",
						"label": "Answer Text"
					}
				]
			}
		],
		"presets": [
			{
				"name": "Slides",
				"blocks": [
					{
						"type": "accordion-item",
						"settings": {
							"question": "How long does production take?",
							"answer": "Most custom pieces are completed within 2–4 weeks depending on the level of personalization."
						}
					},
					{
						"type": "accordion-item",
						"settings": {
							"question": "What type of leather do you use?",
							"answer": "We use premium full-grain leather selected for durability, character, and long-term aging qualities."
						}
					},
					{
						"type": "accordion-item",
						"settings": {
							"question": "Can I request a custom color?",
							"answer": "Yes. We offer several standard colors and can accommodate many custom requests."
						}
					},
					{
						"type": "accordion-item",
						"settings": {
							"question": "Do you offer personalization?",
							"answer": "Absolutely. Initials, names, dates, and custom embossing options are available."
						}
					},
					{
						"type": "accordion-item",
						"settings": {
							"question": "Do you ship internationally?",
							"answer": "Yes, worldwide shipping is available."
						}
					}
				]

			}
		]
	}
{% endschema %}
